[user]
	name = $GIT_NAME
	email = $GIT_EMAIL
	signingkey = $GIT_SIGNINGKEY
[core]
	autocrlf = input
	editor = code --wait
	excludesfile = ~/.config/git/ignore
[status]
	submoduleSummary = true
[credential]
	helper = osxkeychain
[gpg]
	program = $GPG_PATH
[commit]
	gpgsign = true
[credential "https://github.com"]
	helper = 
	helper = !"$GH_PATH" auth git-credential
[credential "https://gist.github.com"]
	helper = 
	helper = !"$GH_PATH" auth git-credential
